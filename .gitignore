# --- Plugin-specific runtime/generated files ---
# guess: 图片库（运行时可变的题库/图片）
xiaozu_bot/plugins/guess/pictures/
xiaozu_bot/plugins/guess/pictures/**

# say: 生成的临时音频与缓存
xiaozu_bot/plugins/say/audios/
xiaozu_bot/plugins/say/*.wav
xiaozu_bot/plugins/say/*.mp3

# gdlevelsearch: 本地缓存/临时数据（如自动抓取的 levels 缓存）
xiaozu_bot/plugins/gdlevelsearch/data/*.json
xiaozu_bot/plugins/gdlevelsearch/data/*.cache
xiaozu_bot/plugins/gdlevelsearch/data/*.tmp
